# Frontend (Vite dev server / build) — see README "Local development"
VITE_NBA2K_API_KEY=
VITE_LAMBDA_URL=
VITE_AUTH_BASE=
VITE_API_BASE=

# Backend (docker compose) — see services/README.md
NBA2K_API_KEY=
ANTHROPIC_API_KEY=
JWT_SECRET=
DEMO_EMAIL=scout@2kscout.app
DEMO_PASSWORD=scout2k

# Observability (docker compose logging driver) — see observability/README.md.
# Requires the EC2 instance to have an IAM role with CloudWatch Logs write access;
# the awslogs Docker logging driver reads credentials from the instance role, not from here.
AWS_REGION=us-east-1
